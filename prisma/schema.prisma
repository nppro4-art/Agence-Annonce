generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String
  name             String?
  plan             String     @default("free")
  planKey          String     @default("free")
  stripeCustomerId String?    @unique
  stripeSubId      String?    @unique
  subStatus        String     @default("inactive")
  refBy            String?
  referralCode     String?    @unique
  referralUsed     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  annonces         Annonce[]
  reponses         Reponse[]
  credits          Credit[]
  purchases        Purchase[]
}

model Employee {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  email       String?
  webhook     String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  clicks      Click[]
  commissions Commission[]
}

model Click {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  ip          String?
  converted   Boolean  @default(false)
  planKey     String?
  createdAt   DateTime @default(now())
}

model Commission {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  userId      String
  amount      Float
  type        String
  planKey     String   @default("business")
  paid        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Annonce {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String
  inputData    Json
  titre        String?
  description  String?
  pointsForts  String?
  defauts      String?
  prixConseil  String?
  shortVersion String?
  score        Int?
  scoreGrade   String?
  createdAt    DateTime @default(now())
}

model Reponse {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  messageAcheteur String
  reponsePrete    String
  suggestion      String?
  createdAt       DateTime @default(now())
}

model Credit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  total     Int      @default(0)
  used      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, type])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  packName  String
  packType  String
  quantity  Int
  amount    Float
  stripeId  String?
  createdAt DateTime @default(now())
}

model Settings {
  id                  String  @id @default("main")
  commissionFirst     Float   @default(6)
  commissionRecurring Float   @default(2)
  commissionStarter   Float   @default(0.50)
  commissionBusiness  Float   @default(1.50)
  commissionExpert    Float   @default(2.50)
  stripePrice         Float   @default(5.99)
  adminWebhook        String?
}
